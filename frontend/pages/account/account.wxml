<view class="container">
  <view class="info-card" wx:if="{{isLoggedIn}}">
    <view class="info-row">
      <text class="row-label">头像</text>
      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-img" wx:if="{{form.avatarUrl}}" src="{{form.avatarUrl}}" mode="aspectFill"></image>
        <view class="avatar-placeholder" wx:else></view>
      </button>
    </view>

    <view class="row-divider"></view>

    <view class="info-row">
      <text class="row-label">名字</text>
      <input
        class="nickname-value"
        type="nickname"
        placeholder="请输入名字"
        maxlength="20"
        value="{{form.nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>
  </view>

  <view class="logout-card" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="onLogoutTap">退出登录</button>
  </view>

  <view class="card empty" wx:else>
    <text class="empty-title">尚未登录</text>
    <text class="empty-desc">请先登录后再设置昵称和头像</text>
    <button class="login-btn" bindtap="onGoLogin">去登录</button>
  </view>
</view>
