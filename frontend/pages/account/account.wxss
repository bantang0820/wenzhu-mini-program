.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.info-card,
.logout-card,
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.info-card {
  overflow: hidden;
}

.info-row {
  min-height: 148rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 36rpx;
}

.row-label {
  font-size: 30rpx;
  color: #111111;
  font-weight: 500;
}

.row-divider {
  margin: 0 28rpx;
  height: 1rpx;
  background: #F0F0F0;
}

.avatar-picker {
  width: 96rpx;
  height: 96rpx;
  border: none;
  border-radius: 20rpx;
  margin-left: auto;
  padding: 0;
  background: transparent;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-picker::after {
  border: none;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  background: #F3F3F3;
}

.nickname-value {
  min-width: 260rpx;
  height: 60rpx;
  text-align: right;
  font-size: 30rpx;
  color: #B7B7B7;
  background: transparent;
  border: none;
  padding: 0;
}

.logout-btn {
  width: 100%;
  height: 112rpx;
  line-height: 112rpx;
  border-radius: 24rpx;
  border: none;
  background: #FFFFFF;
  color: #F25555;
  font-size: 32rpx;
  font-weight: 500;
}

.logout-btn::after {
  border: none;
}

.logout-card {
  margin-top: 28rpx;
  padding: 0 28rpx;
}

.empty {
  text-align: center;
  padding: 48rpx 28rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  color: #2B303A;
  font-weight: 600;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(106, 97, 90, 0.85);
  font-size: 24rpx;
}

.login-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 43rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #D4AF37 0%, #E8C65A 100%);
  color: #FFFFFF;
}

.login-btn::after {
  border: none;
}
