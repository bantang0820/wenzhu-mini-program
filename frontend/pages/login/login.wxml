<!--pages/login/login.wxml - 登录/注册-->
<view class="container">
  <view class="login-content">
    <view class="logo-section">
      <view class="logo-orb"></view>
      <text class="logo-title">稳住</text>
      <text class="logo-subtitle">做不焦虑的父母，给孩子更好的爱</text>
    </view>

    <view class="auth-section">
      <!-- 快速登录按钮 -->
      <button
        class="login-btn primary"
        loading="{{loading}}"
        disabled="{{loading}}"
        open-type="agreePrivacyAuthorization"
        bindtap="onQuickLoginTap"
        bindagreeprivacyauthorization="onAgreePrivacyAuthorization"
      >
        {{loading ? '登录中...' : '一键登录'}}
      </button>

      <view class="privacy-note">
        登录即表示同意 <text class="link">《服务协议》</text> 与 <text class="link" bindtap="openPrivacyContract">{{privacyContractName}}</text>
      </view>
      <view class="privacy-note" wx:if="{{needPrivacyAuthorization}}">
        <text>首次登录前需先同意隐私保护指引</text>
      </view>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="bottom-decoration">
    <view class="mist"></view>
  </view>
</view>
