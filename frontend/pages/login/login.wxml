<!--pages/login/login.wxml - 登录/注册-->
<view class="container">
  <view class="login-content">
    <view class="logo-section">
      <view class="logo-orb"></view>
      <text class="logo-title">稳住</text>
      <text class="logo-subtitle">做不焦虑的父母，给孩子更好的爱</text>
    </view>

    <view class="auth-section">
      <!-- 快速登录按钮 -->
      <button
        class="login-btn primary {{privacyShake}}"
        loading="{{loading}}"
        open-type="agreePrivacyAuthorization"
        bindtap="onQuickLoginTap"
        bindagreeprivacyauthorization="onAgreePrivacyAuthorization"
      >
        {{loading ? '登录中...' : '一键登录'}}
      </button>

      <!-- 隐私政策复选框 -->
      <view class="privacy-checkbox-wrapper {{privacyShake}}">
        <checkbox-group bindchange="onPrivacyCheckboxChange">
          <label class="privacy-checkbox-label">
            <checkbox value="privacy" checked="{{privacyChecked}}" class="privacy-checkbox" color="#2B303A"/>
            <text class="privacy-text">我已阅读并同意</text>
            <text class="link" catchtap="openPrivacyContract">《服务协议》</text>
            <text class="privacy-text">和</text>
            <text class="link" catchtap="openPrivacyContract">{{privacyContractName}}</text>
          </label>
        </checkbox-group>
      </view>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="bottom-decoration">
    <view class="mist"></view>
  </view>
</view>
