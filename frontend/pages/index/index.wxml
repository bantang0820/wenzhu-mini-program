<!--pages/index/index.wxml - 天人地布局-->
<view class="container">
  <!-- ========== 天：顶层世界观 Slogan ========== -->
  <view class="top-header">
    <text class="header-text">在你崩溃那30秒，稳稳接住你</text>
  </view>

  <!-- ========== 人：呼吸之核 ========== -->
  <view class="top-zone">
    <view class="breathing-core-container">
      <view
        class="breathing-core {{isBreathing ? 'breathing' : ''}}"
        bindtap="onBreathTap"
      >
        <!-- 内部光晕 -->
        <view class="core-inner"></view>

        <!-- 外部光晕 -->
        <view class="core-outer"></view>

        <!-- 核心文字 -->
        <view class="core-text">
          <text class="core-main title-serif">稳住</text>
          <text class="core-sub">点击进入正念朗读</text>
        </view>

        <!-- 涟漪效果 -->
        <view class="ripple-effect" wx:if="{{showRipple}}">
          <view class="ripple-wave"></view>
          <view class="ripple-wave"></view>
          <view class="ripple-wave"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 地：场景引导 + 矩阵 ========== -->
  <view class="bottom-zone">
    <view class="scenarios-container">
      <!-- 引导文案 -->
      <view class="section-guide">
        <text class="guide-line">——</text>
        <text class="guide-text">也可选择场景进行专项朗读练习</text>
        <text class="guide-line">——</text>
      </view>

      <!-- Top 6 高频急救区 -->
      <view class="hero-section">
        <view class="hero-grid">
          <view
            class="hero-card"
            wx:for="{{heroScenarios}}"
            wx:key="id"
            bindtap="onScenarioTap"
            data-id="{{item.id}}"
          >
            <text class="hero-icon">{{item.icon}}</text>
            <text class="hero-title">{{item.title}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 分享解锁弹窗 ========== -->
  <view class="share-modal-mask {{showShareModal ? 'show' : ''}}" bindtap="closeShareModal" wx:if="{{showShareModal}}">
    <view class="share-modal-content" catchtap="catchTouch">
      <view class="share-modal-header">
        <view class="share-modal-icon-wrapper">
          <text class="share-modal-icon">🕊️</text>
        </view>
      </view>
      <text class="share-modal-title title-serif">获取额外朗读机会</text>
      
      <view class="share-modal-desc-container">
        <text class="share-modal-quote">"先稳住自己，再拥抱孩子。"</text>
        <text class="share-modal-desc">今天的 3 次朗读练习已经完成。\n我想把这份让情绪安定的力量分享给你。\n这样，我和你都能额外获得 1 次朗读机会。</text>
      </view>
      
      <view class="share-modal-actions">
        <button class="share-modal-btn primary-btn" open-type="share" id="unlockShareBtn">
          分享给朋友
        </button>
        <view class="share-modal-btn secondary-btn" bindtap="goToPro">
          不想分享，直接开通会员
        </view>
      </view>
    </view>
  </view>
</view>
